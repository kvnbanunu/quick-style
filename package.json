{
  "name": "quick-style-hackathon",
  "version": "1.0.40",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./babel-plugin": "./src/utils/babel-plugin-source.js",
    "./style.css": "./dist/index.css" 
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-tailwind-runtime-source.mjs",
    "build": "vite build",
    "lint": "eslint .",
    "local:package": "npm run prebuild && vite build && node -e \"require('fs').mkdirSync('.local-packages',{recursive:true})\" && npm pack --pack-destination .local-packages",
    "local:link": "npm run prebuild && vite build && npm link",
    "local:unlink": "npm unlink"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "vite-plugin-dts": "^4.0.0", 
    "typescript": "^5.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.2.1"
  }
}